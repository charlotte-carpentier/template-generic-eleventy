{# ┌─────────────────────────────────────────────────────────┐
   │ ORGANISM › Error Layout                                 │
   │ Complete error page layout with halo reveal system      │
   └─────────────────────────────────────────────────────────┘ #}

{#
  Usage — Summon HAT Components Wisely:
    {% from "03-organisms/error-layout.njk" import renderErrorLayout %}

    {{ renderErrorLayout({
        name: "errLayout404",
        datas: organisms["error-layout"].errorLayouts,
        fragmentGroupDatas: molecules["error-fragment-group"].errorFragmentGroups,
        headingDatas: atoms.heading.headings,
        buttonDatas: atoms.button.buttons,
        linkDatas: atoms.link.links,
        iconDatas: atoms.icon.icons
    }) }}

  @created 2025-01-15
  @updated 2026-03-04 - Migrated to HAT v1 patterns
#}

{% from "02-molecules/error-fragment-group.njk" import renderErrorFragmentGroup %}
{% from "01-atoms/heading.njk" import renderHeading %}
{% from "01-atoms/button.njk" import renderButton %}
{% from "01-atoms/link.njk" import renderLink %}
{% from "01-atoms/icon.njk" import renderIcon %}

{% macro renderErrorLayout(options) %}

  {# ━━━━━━━━━━━━━━━━━━━━━━━━━━
    1. Validate Props
  ━━━━━━━━━━━━━━━━━━━━━━━━━ #}
  {% if not options.datas %}
    <span class="error" role="alert">Error: Missing required prop (datas)</span>
  {% elif not options.name %}
    <span class="error" role="alert">Error: Missing required prop (name)</span>
  {% else %}
    {% set layoutData = options.datas | findByName(options.name) %}

    {% if not layoutData %}
      <span class="error" role="alert">Error layout not found: {{ options.name }}</span>
    {% else %}

      {# ━━━━━━━━━━━━━━━━━━━━━━━━━━
        2. Compute Final Values
      ━━━━━━━━━━━━━━━━━━━━━━━━━ #}
      {% set titleHeadingName = layoutData.titleHeadingName | default('') %}
      {% set subtitleHeadingName = layoutData.subtitleHeadingName | default('') %}
      {% set linkName = layoutData.linkName | default('') %}
      {% set groupName = layoutData.groupName | default('') %}
      {% set a11yHeadingName = layoutData.a11yHeadingName | default('') %}
      {% set a11yBtnName = layoutData.a11yBtnName | default('') %}

      {# ━━━━━━━━━━━━━━━━━━━━━━━━━━
        3. Tailwind Classes
        Index:
        3.1 Wrapper Classes
        3.2 Desktop Layout Classes
        3.3 Desktop Fragments Classes
        3.4 Triptych Classes
        3.5 Mobile Layout Classes
        3.6 Mobile Fragments Classes
        3.7 Accessibility Classes
      ━━━━━━━━━━━━━━━━━━━━━━━━━ #}

      {# --------------------------
          3.1 Wrapper Classes
        --------------------------#}
      {% set wrapperClasses = "relative w-full min-h-screen overflow-hidden" %}

      {# --------------------------
          3.2 Desktop Layout Classes
        --------------------------#}
      {% set desktopClasses = "hidden lg:grid lg:grid-cols-3 lg:grid-rows-3 w-full h-screen" %}

      {# --------------------------
          3.3 Desktop Fragments Classes
        --------------------------#}
      {% set fragmentsDesktopClasses = "contents" %}

      {# --------------------------
          3.4 Triptych Classes
        --------------------------#}
      {% set triptychClasses = "absolute inset-0 flex flex-col items-center justify-center gap-[var(--spacing-ui-default)] z-[var(--z-modal)] px-[var(--spacing-ui-comfortable)]" %}
      {% set triptychMobileClasses = "flex flex-col items-center gap-[var(--spacing-ui-default)] px-[var(--grid-margin-mobile)] py-[var(--spacing-section-minimal)]" %}
      {% set triptychTitleClasses = "text-center" %}
      {% set triptychSubtitleClasses = "text-center" %}
      {% set triptychCtaClasses = "flex justify-center" %}
      {% set triptychA11yClasses = "flex flex-col items-center gap-[var(--spacing-ui-minimal)] mt-[var(--spacing-ui-maximal)]" %}

      {# --------------------------
          3.5 Mobile Layout Classes
        --------------------------#}
      {% set mobileClasses = "flex flex-col lg:hidden overflow-y-auto" %}

      {# --------------------------
          3.6 Mobile Fragments Classes
        --------------------------#}
      {% set fragmentsMobileClasses = "flex flex-col gap-[var(--spacing-ui-default)] px-[var(--grid-margin-mobile)] py-[var(--spacing-section-minimal)]" %}
      {% set fragmentMobileItemClasses = "flex items-center justify-center min-h-[120px]" %}
      {% set clickableMobileClasses = "bg-transparent border-0 p-0 cursor-pointer focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-[var(--color-semantic-information-focus)] rounded-[var(--radius-default)]" %}

      {# --------------------------
          3.7 Accessibility Classes
        --------------------------#}
      {% set a11yClasses = "flex flex-col items-center gap-[var(--spacing-ui-minimal)]" %}

      {# ━━━━━━━━━━━━━━━━━━━━━━━━━━
        4. Render HTML
      ━━━━━━━━━━━━━━━━━━━━━━━━━ #}
      <div
        class="{{ wrapperClasses }}"
        data-error-layout-name="{{ layoutData.name }}"
        data-error-layout-type="error-layout"
      >

        {# ── Desktop ── #}
        <div
          class="{{ desktopClasses }}"
          data-error-layout-desktop
        >

          <div
            class="{{ fragmentsDesktopClasses }}"
            data-error-layout-fragments
          >
            {{ renderErrorFragmentGroup({
                name: groupName,
                datas: options.fragmentGroupDatas,
                iconDatas: options.iconDatas,
                headingDatas: options.headingDatas
            }) }}
          </div>

          <div
            class="{{ triptychClasses }}"
            data-error-layout-triptych
          >

            {% if titleHeadingName %}
              <div class="{{ triptychTitleClasses }}" data-triptych-title>
                {{ renderHeading({ name: titleHeadingName, datas: options.headingDatas }) }}
              </div>
            {% endif %}

            {% if subtitleHeadingName %}
              <div class="{{ triptychSubtitleClasses }}" data-triptych-subtitle>
                {{ renderHeading({ name: subtitleHeadingName, datas: options.headingDatas }) }}
              </div>
            {% endif %}

            {% if linkName %}
              <div class="{{ triptychCtaClasses }}" data-triptych-cta>
                {{ renderLink({ name: linkName, datas: options.linkDatas }) }}
              </div>
            {% endif %}

            {% if a11yHeadingName and a11yBtnName %}
              <div class="{{ triptychA11yClasses }}" data-triptych-a11y>
                <div class="{{ a11yClasses }}" data-a11y-controls>
                  <div data-a11y-text>
                    {{ renderHeading({ name: a11yHeadingName, datas: options.headingDatas }) }}
                  </div>
                  <div data-a11y-button>
                    {{ renderButton({ name: a11yBtnName, datas: options.buttonDatas }) }}
                  </div>
                </div>
              </div>
            {% endif %}

          </div>

        </div>

        {# ── Mobile ── #}
        <div
          class="{{ mobileClasses }}"
          data-error-layout-mobile
        >

          <div
            class="{{ triptychMobileClasses }}"
            data-error-layout-triptych-mobile
          >

            {% if titleHeadingName %}
              <div class="{{ triptychTitleClasses }}" data-triptych-title>
                {{ renderHeading({ name: titleHeadingName, datas: options.headingDatas }) }}
              </div>
            {% endif %}

            {% if subtitleHeadingName %}
              <div class="{{ triptychSubtitleClasses }}" data-triptych-subtitle>
                {{ renderHeading({ name: subtitleHeadingName, datas: options.headingDatas }) }}
              </div>
            {% endif %}

            {% if linkName %}
              <div class="{{ triptychCtaClasses }}" data-triptych-cta>
                {{ renderLink({ name: linkName, datas: options.linkDatas }) }}
              </div>
            {% endif %}

            {% if a11yHeadingName and a11yBtnName %}
              <div class="{{ triptychA11yClasses }}" data-triptych-a11y>
                <div class="{{ a11yClasses }}" data-a11y-controls>
                  <div data-a11y-text>
                    {{ renderHeading({ name: a11yHeadingName, datas: options.headingDatas }) }}
                  </div>
                  <div data-a11y-button>
                    {{ renderButton({ name: a11yBtnName, datas: options.buttonDatas }) }}
                  </div>
                </div>
              </div>
            {% endif %}

          </div>

          {% set groupData = options.fragmentGroupDatas | findByName(groupName) %}
          {% if groupData and groupData.fragments %}
            <div
              class="{{ fragmentsMobileClasses }}"
              data-error-layout-fragments-mobile
            >
              {% for fragment in groupData.fragments %}
                {% set isFragment6 = loop.index == 6 %}
                {% set isClickable = isFragment6 and not groupData.disableFragment6Click %}

                <div
                  class="{{ fragmentMobileItemClasses }}"
                  data-fragment-mobile-item
                  data-fragment-index="{{ loop.index }}"
                >

                  {% if isClickable %}
                    <a
                      href="/"
                      class="{{ clickableMobileClasses }}"
                      aria-label="Retourner à l'accueil"
                    >
                  {% endif %}

                  {% if fragment.variant == "icon" and fragment.iconName and options.iconDatas %}
                    {{ renderIcon({ name: fragment.iconName, datas: options.iconDatas }) }}
                  {% elif fragment.variant == "text" and fragment.textHeadingName and options.headingDatas %}
                    {{ renderHeading({ name: fragment.textHeadingName, datas: options.headingDatas }) }}
                  {% endif %}

                  {% if isClickable %}
                    </a>
                  {% endif %}

                </div>
              {% endfor %}
            </div>
          {% endif %}

        </div>

      </div>
    {% endif %}
  {% endif %}
{% endmacro %}

